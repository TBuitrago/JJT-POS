# ============================================================
# Culto Orquídeas POS — Backend · Variables de entorno
# Copiar como .env y completar valores reales
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://<proyecto>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Servidor ─────────────────────────────────────────────────
# En Hostinger Node.js Apps el PORT lo asigna la plataforma automáticamente.
# No lo configures manualmente en producción — déjalo sin valor o elimínalo.
PORT=3001
NODE_ENV=development
# En producción: NODE_ENV=production (activa el serving del frontend estático)
# FRONTEND_URL en producción = tu dominio real (solo relevante para CORS externo)
FRONTEND_URL=http://localhost:5173

# ── Email (Hostinger SMTP) ───────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=pos@tudominio.com
SMTP_PASS=
EMAIL_FROM=Culto Orquídeas <pos@tudominio.com>
